    "test:coverage": "vitest run --coverage",
    "cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "picocolors": "^1.0.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "pdfkit": "^0.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/pdfkit": "^0.13.4",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^1.5.0",
    "supertest": "^7.0.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
