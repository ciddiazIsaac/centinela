{
  "name": "centinela",
  "version": "0.1.0",
  "description": "Centinela - escáner de seguridad HTTP: headers, CORS, cookies y rutas expuestas",
  "main": "dist/index.js",
  "bin": {
    "centinela": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
